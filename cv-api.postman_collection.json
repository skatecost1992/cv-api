{
  "info": {
    "name": "CV API",
    "description": "Colección para consumir la API de hoja de vida (cv-api). Configura las variables baseUrl, apiKey y apiValue en la pestaña Variables de la colección.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://cv-api-xxxx.onrender.com" },
    { "key": "apiKey", "value": "app-cv" },
    { "key": "apiValue", "value": "" }
  ],
  "item": [
    {
      "name": "Seguridad",
      "item": [
        {
          "name": "GET clave pública (abierto)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/public-key", "host": ["{{baseUrl}}"], "path": ["public-key"] }
          }
        }
      ]
    },
    {
      "name": "Info Personal",
      "item": [
        {
          "name": "GET info personal",
          "request": {
            "method": "GET",
            "header": [
